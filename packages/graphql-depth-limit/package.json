{
	"name": "@graphqlava/graphql-depth-limit",
	"version": "1.2.4",
	"description": "GraphQL validation rule for rejecting operations that exceed a maximum depth.",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"license": "UNLICENSED",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/charliewilco/graphqlava.git",
		"directory": "packages/graphql-depth-limit"
	},
	"homepage": "https://github.com/charliewilco/graphqlava#readme",
	"bugs": {
		"url": "https://github.com/charliewilco/graphqlava/issues"
	},
	"keywords": [
		"graphql",
		"validation",
		"query-depth",
		"security"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "node --import tsx --test test/*.test.ts",
		"typecheck": "tsc --noEmit --pretty"
	},
	"devDependencies": {
		"@types/node": "^24.12.2",
		"graphql": "^16.13.2",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"graphql": "^16.13.2"
	}
}
