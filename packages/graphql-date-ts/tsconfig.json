{
	"compilerOptions": {
		"outDir": "dist",
		"module": "esnext",
		"target": "esnext",
		"lib": ["es2017", "dom"],
		"sourceMap": true,
		"allowJs": false,
		"declaration": true,
		"esModuleInterop": true,
		"moduleResolution": "bundler",
		"paths": {
			"@graphqlava/graphql-ast-assertions": [
				"../graphql-ast-assertions/src/index.ts"
			]
		},
		"rootDir": "..",
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
