{
	"name": "@graphqlava/graphql-date-ts",
	"version": "1.2.3",
	"description": "RFC 3339 GraphQL date, time, and date-time scalars.",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"license": "UNLICENSED",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/charliewilco/graphqlava.git",
		"directory": "packages/graphql-date-ts"
	},
	"homepage": "https://github.com/charliewilco/graphqlava#readme",
	"bugs": {
		"url": "https://github.com/charliewilco/graphqlava/issues"
	},
	"keywords": [
		"graphql",
		"scalar",
		"date",
		"time",
		"rfc3339"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"engines": {
		"node": ">=18.18.0"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "node --import tsx --test test/*.test.ts",
		"typecheck": "tsc --noEmit --pretty"
	},
	"dependencies": {
		"@graphqlava/graphql-ast-assertions": "^1.2.3"
	},
	"devDependencies": {
		"@types/node": "^24.12.2",
		"graphql": "^16.13.2",
		"mockdate": "^3.0.5",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"graphql": "^16.13.2"
	}
}
