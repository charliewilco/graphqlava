{
	"private": true,
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "bun run --workspaces --sequential build",
		"check": "bun run format && bun run typecheck && bun run build && bun run test",
		"format": "prettier --check .",
		"format:write": "prettier --write .",
		"test": "bun run --workspaces --sequential test",
		"typecheck": "bun run --workspaces --sequential typecheck"
	},
	"devDependencies": {
		"prettier": "^3.8.2"
	}
}
